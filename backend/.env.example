# REQUIRED — PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/project_manager

# CORS — comma-separated allowed origins  (default: http://localhost:5173)
CORS_ORIGINS=["http://localhost:5173"]

# LLM — single provider (OpenAI-compatible: OpenAI, Groq, Together, etc.)
# REQUIRED
API_KEY=your_api_key_here
# optional (default: https://api.openai.com/v1)
LLM_BASE_URL=https://api.openai.com/v1
# optional (default: gpt-4o)
LLM_MODEL=gpt-4o
